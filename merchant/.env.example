# --- API environment ---
# development = local server on :2026
# production  = cloud API (or test cloud while running next dev locally)
NEXT_PUBLIC_APP_ENV=development

# Cloud API — required when NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_PRODUCTION_API_URL=https://qarego.onrender.com

# Optional overrides (development only — usually leave as localhost)
API_PROXY_TARGET=http://127.0.0.1:2026
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:2026
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:2026

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase web push (merchant kitchen)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Hosted deploy (Vercel / Netlify) — set in dashboard, not in git ---
# NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_PRODUCTION_API_URL=https://qarego.onrender.com
# API_PROXY_TARGET=https://qarego.onrender.com
# NEXT_PUBLIC_API_BASE_URL=https://qarego.onrender.com
# NEXT_PUBLIC_SOCKET_URL=https://qarego.onrender.com
# Render: MERCHANT_ORIGIN=https://your-merchant.vercel.app
