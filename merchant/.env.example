# --- Local dev ---
# Backend URL for the Next.js /api proxy (default http://127.0.0.1:2026)
API_PROXY_TARGET=http://127.0.0.1:2026

# Google Maps key (same key used across the QareGO system)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Backend origin for socket, uploads, and kitchen alert sounds.
# Use your Mac LAN IP when opening merchant on a tablet/phone on Wi‑Fi (e.g. http://192.168.1.10:2026).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:2026

# Legacy alias — prefer NEXT_PUBLIC_API_BASE_URL
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:2026

# Optional — FCM web push for merchant kitchen (Firebase Console → add Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Production (Vercel — all three required) ---
# API_PROXY_TARGET=https://qarego.onrender.com
# NEXT_PUBLIC_API_BASE_URL=https://qarego.onrender.com
# NEXT_PUBLIC_SOCKET_URL=https://qarego.onrender.com
# Also on Render: MERCHANT_ORIGIN=https://qarego-merchant.vercel.app
# Redeploy merchant after changing env vars (NEXT_PUBLIC_* are baked at build time).
