# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/qarego

# JWT
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# CORS (optional)
ADMIN_ORIGIN=http://localhost:3000
MERCHANT_ORIGIN=http://localhost:3001

# --- Cloudinary (image uploads) ---
# Create free account: https://cloudinary.com/console
# Option A: paste full URL from Dashboard (recommended)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: separate values (must match the same Cloudinary account)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional default folder in Cloudinary media library
CLOUDINARY_FOLDER=qarego

# --- Firebase Cloud Messaging (push) ---
# Firebase Console → Project settings → Service accounts → Generate new private key
# Paste the JSON as a single line, or set FIREBASE_SERVICE_ACCOUNT_PATH to the .json file path
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# SMS (Arkasel) — new-order alerts to vendor owners & cooks
ARKASEL_API_KEY=
ARKASEL_API_SECRET=
ARKASEL_SENDER_ID=QareGO

# FCM only — register Android + iOS apps in Firebase; see FIREBASE_PUSH_SETUP.md
