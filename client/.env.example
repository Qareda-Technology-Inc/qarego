# JS maps (Places, geocoding, directions) — set on EAS for preview/production builds too
EXPO_PUBLIC_MAP_API_KEY=your_google_maps_key

# --- API environment ---
# development = local Mac server (USB / Wi‑Fi auto-discovery)
# production  = cloud API (TestFlight, or npm run start:cloud)
EXPO_PUBLIC_APP_ENV=development

# Cloud API — required when EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_PRODUCTION_API_URL=https://qarego.onrender.com

# Dev-only override when EXPO_PUBLIC_APP_ENV=development (usually leave commented)
# EXPO_PUBLIC_API_URL=http://192.168.1.XXX:2026

EXPO_NO_DEPENDENCY_VALIDATION=1
# Native map tiles (react-native-maps on Android/iOS) — set on EAS for preview/production builds too
GOOGLE_API_KEY=your_new_safe_key_here
